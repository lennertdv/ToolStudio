rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "devlamincklennert@gmail.com"
      );
    }

    function isValidPageview(data) {
      return data.toolId is string && data.toolId.size() < 100 &&
             data.categoryId is string && data.categoryId.size() < 100 &&
             data.path is string && data.path.size() < 200 &&
             data.timestamp == request.time;
    }

    // Pageviews: Users can only create. Admins can read.
    match /pageviews/{viewId} {
      allow create: if isValidPageview(request.resource.data);
      allow read, list, delete, update: if isAdmin();
    }

    // Admins: Only admins can read/write admins collection (bootstrapped)
    match /admins/{userId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
